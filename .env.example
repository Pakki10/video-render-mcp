# --- Required ---
# Postgres connection string. Docker Compose provides this automatically.
DATABASE_URL="postgresql://admin:admin@db:5432/video_render_mcp"

# NextAuth — generate a random 32-byte value.  openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000/api/auth/callback/google and your production URL as redirect URIs.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Optional ---
# Rendering
REMOTION_CHROME_EXECUTABLE=/usr/bin/chromium
# Where rendered MP4s are written (must be writable by the app user).
RENDER_DATA_DIR=/app/data
# Public base URL rewritten into the videoUrl returned by render_video.
# Set this on prod (e.g. https://video-render.regiq.in) so tool results
# hand back absolute URLs.
PUBLIC_BASE_URL=""

# Quota
DAILY_RENDER_QUOTA=20

# If the user brings an ElevenLabs key, we route through them for better voice.
# Otherwise we default to msedge-tts (free, no key).
ELEVENLABS_API_KEY=""
